# Job Agent Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API key for AI-enhanced job analysis (server-side)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model to use (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# App name displayed in UI
NEXT_PUBLIC_APP_NAME="Job Agent"

# ── Adzuna API (optional — adds Danish + international job listings) ──────────
# Free tier: 250 calls/month. Sign up at https://developer.adzuna.com/
# After registering: Dashboard → My Apps → copy App ID and App Key
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Adzuna country code to search (default: dk for Denmark)
# Options: dk, gb, us, de, nl, se, no, fi, fr, au, ca
ADZUNA_COUNTRY=dk

# ── MCP Server API Keys (optional — enables advanced agent capabilities) ──────
# Brave Search API key for web search MCP server
# Free tier: 2000 queries/month. Get at https://brave.com/search/api/
BRAVE_API_KEY=

# GitHub personal access token for GitHub MCP server
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=