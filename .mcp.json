{
  "mcpServers": {
    "claude-flow": {
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "5",
        "CLAUDE_FLOW_MEMORY_BACKEND": "memory"
      },
      "autoStart": false
    },
    "filesystem": {
      "command": "node",
      "args": [
        "scripts/mcp-launcher.js",
        "filesystem"
      ],
      "autoStart": true
    },
    "playwright": {
      "command": "node",
      "args": [
        "scripts/mcp-launcher.js",
        "playwright"
      ],
      "autoStart": true
    },
    "github": {
      "command": "node",
      "args": [
        "scripts/mcp-launcher.js",
        "github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      },
      "autoStart": false
    },
    "sqlite": {
      "command": "node",
      "args": [
        "scripts/mcp-launcher.js",
        "sqlite"
      ],
      "autoStart": true
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
      },
      "autoStart": true
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "autoStart": true
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "autoStart": true
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@hisma/server-puppeteer"
      ],
      "autoStart": true
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-fetch-server"
      ],
      "autoStart": true
    }
  }
}
