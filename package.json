{
  "name": "job-agent",
  "version": "0.4.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:fast": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "mcp:bridge": "node scripts/mcp-bridge.js",
    "mcp:start": "npm run mcp:bridge",
    "browser:check": "node scripts/browser-check.js",
    "daemon": "npx tsx scripts/daemon.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run test && npm run typecheck && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@ai-sdk/react": "^4.0.5",
    "@types/imap-simple": "^4.2.10",
    "@types/mailparser": "^3.4.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "ai": "^6.0.208",
    "docx": "^9.7.1",
    "framer-motion": "^12.42.0",
    "html2canvas": "^1.4.1",
    "imap-simple": "^5.1.0",
    "jspdf": "^4.2.1",
    "mailparser": "^3.9.12",
    "next": "^15.1.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "ollama-ai-provider": "^1.2.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
